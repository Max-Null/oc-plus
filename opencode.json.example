{
  "$schema": "https://opencode.ai/config.json",

  // ── 默认模型：provider名:模型名 ──
  // provider 名（如 ds）对应下方 provider 段的 key，模型名对应 provider.models 中的 key
  "model": "ds:deepseek-v4-pro",
  "default_agent": "双星",

  // ── 插件 ──
  "plugin": [
    "~/.config/opencode/node_modules/superpowers",
    "opencode-acp@latest",
    // fractal 由 OC 自动发现 ~/.config/opencode/plugins/fractal.ts，无需在此列出
    "agents-priority"
  ],

  // ── 禁用 OC 内置压缩（由 opencode-acp 接管）──
  // ACP 安装命令：opencode plugin opencode-acp@latest --global
  "compaction": { "auto": false },

  // ── 模型提供商 ──
  "provider": {
    "ds": {
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "reasoning": true
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "reasoning": true
        }
      },
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        // ⚠️ 替换为你的 DeepSeek API Key：https://platform.deepseek.com/api_keys
        "apiKey": "sk-your-deepseek-api-key",
        "baseURL": "https://api.deepseek.com/v1",
        "setCacheKey": true
      }
    }
  },

  // ── MCP 服务器 ──
  "mcp": {
    // GitHub MCP：代码仓库操作（PR/Issue/搜索），需要 GitHub PAT
    // 获取 PAT：https://github.com/settings/tokens → 勾选 repo + read:org
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "env": {
        "GITHUB_TOKEN": "ghp_your-github-pat"
      }
    },

    // websearch MCP：Exa AI 搜索（免费匿名可用，有速率限制）
    // 提升额度：https://dashboard.exa.ai/api-keys 获取 Key → 加入 env
    "websearch": {
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa"
    },

    // gh_grep MCP：GitHub 代码全文搜索（无需认证）
    "gh_grep": {
      "url": "https://mcp.grep.app"
    },

    // context7 MCP：实时库文档查询（免费 1,000 次/月，无需 Key）
    // 提升额度：https://context7.com → 注册 → Dashboard 生成 Key → CONTEXT7_API_KEY
    "context7": {
      "url": "https://mcp.context7.com/mcp"
    }
  },

  // ── 工具权限（全局兜底）──
  "permissions": {
    "github": "allow",
    "websearch": "allow",
    "webfetch": "allow",
    "gh_grep": "allow",
    "context7": "allow"
  }
}
